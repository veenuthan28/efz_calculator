---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <main class="mx-auto max-w-app stack-xl">
    <section class="glass-card header">
      <span class="badge">BiVo 2021 · Informatiker EFZ</span>
      <h1>QV Notenrechner <span class="accent">IPA + IK</span></h1>
      <p class="subtitle">Schnelle, klare Schätzung deiner Abschlussnote.</p>
      <p class="trust-note">This is an estimation based on your input.</p>
    </section>

    <section class="glass-card toolbar" aria-label="Steuerung">
      <div class="bm-wrap">
        <span id="labelNoBm" class="bm-label active">Ohne BM</span>
        <label class="switch" for="bmToggle">
          <input type="checkbox" id="bmToggle" />
          <span class="track"></span>
          <span class="thumb"></span>
        </label>
        <span id="labelBm" class="bm-label">Mit BM</span>
      </div>
      <button id="resetBtn" class="btn-reset" type="button">
        Eingaben zurücksetzen
      </button>
    </section>

    <section class="layout" aria-label="Notenformular und Resultat">
      <div class="sections stack-lg">
        <article class="section" id="sectionIpa">
          <div class="section-head">
            <h2 class="section-title">IPA · Individuelle Praktische Arbeit</h2>
            <div class="section-meta">
              <span class="pill" id="ipaWeight">40%</span>
              <span class="section-grade" id="ipaGrade">-</span>
            </div>
          </div>
          <div class="section-body">
            <div class="field-row">
              <label class="field-label" for="ipaArbeit">
                Resultat der Arbeit
                <span class="field-hint">Gewichtung 50% · Eingabe 1.0 bis 6.0</span>
              </label>
              <input
                class="input-grade"
                id="ipaArbeit"
                type="number"
                min="1"
                max="6"
                step="0.1"
                inputmode="decimal"
                placeholder="5.0"
              />
            </div>
            <div class="field-row">
              <label class="field-label" for="ipaDok">
                Dokumentation
                <span class="field-hint">Gewichtung 20%</span>
              </label>
              <input
                class="input-grade"
                id="ipaDok"
                type="number"
                min="1"
                max="6"
                step="0.1"
                inputmode="decimal"
                placeholder="5.0"
              />
            </div>
            <div class="field-row">
              <label class="field-label" for="ipaFach">
                Fachgespräch / Präsentation
                <span class="field-hint">Gewichtung 30%</span>
              </label>
              <input
                class="input-grade"
                id="ipaFach"
                type="number"
                min="1"
                max="6"
                step="0.1"
                inputmode="decimal"
                placeholder="5.0"
              />
            </div>
          </div>
        </article>

        <article class="section" id="sectionIk">
          <div class="section-head">
            <h2 class="section-title">IK · Informatikkompetenzen</h2>
            <div class="section-meta">
              <span class="pill" id="ikWeight">30%</span>
              <span class="section-grade" id="ikGrade">-</span>
            </div>
          </div>
          <div class="section-body">
            <div class="field-row">
              <label class="field-label" for="ikBfs">
                BFS Durchschnitt
                <span class="field-hint">Gewichtung 80% · Erfahrungsnote auf 0.5</span>
              </label>
              <input
                class="input-grade"
                id="ikBfs"
                type="number"
                min="1"
                max="6"
                step="0.1"
                inputmode="decimal"
                placeholder="5.0"
              />
            </div>
            <div class="field-row">
              <label class="field-label" for="ikUek">
                ÜK Durchschnitt
                <span class="field-hint">Gewichtung 20% · Erfahrungsnote auf 0.5</span>
              </label>
              <input
                class="input-grade"
                id="ikUek"
                type="number"
                min="1"
                max="6"
                step="0.1"
                inputmode="decimal"
                placeholder="5.0"
              />
            </div>
          </div>
        </article>

        <article class="section" id="sectionEgk">
          <div class="section-head">
            <h2 class="section-title">eGK · Erweiterte Grundkompetenzen</h2>
            <div class="section-meta">
              <span class="pill">10%</span>
              <span class="section-grade" id="egkGrade">-</span>
            </div>
          </div>
          <div class="section-body">
            <div class="field-row">
              <label class="field-label" for="egkSchnitt">
                Durchschnitt Mathe + Englisch
                <span class="field-hint">Semesterschnitt als Erfahrungsnote · auf 0.5 gerundet</span>
              </label>
              <input
                class="input-grade"
                id="egkSchnitt"
                type="number"
                min="1"
                max="6"
                step="0.1"
                inputmode="decimal"
                placeholder="5.0"
              />
            </div>
          </div>
        </article>

        <article class="section" id="sectionAbu">
          <div class="section-head">
            <h2 class="section-title">ABU · Allgemeinbildung</h2>
            <div class="section-meta">
              <span class="pill">20%</span>
              <span class="section-grade" id="abuGrade">-</span>
            </div>
          </div>
          <div class="section-body">
            <div class="field-row">
              <label class="field-label" for="abuErfa">
                Erfa Note
                <span class="field-hint">Teil von (Erfa + VA + Schluss) / 3</span>
              </label>
              <input
                class="input-grade"
                id="abuErfa"
                type="number"
                min="1"
                max="6"
                step="0.1"
                inputmode="decimal"
                placeholder="5.0"
              />
            </div>
            <div class="field-row">
              <label class="field-label" for="abuVa">
                Vertiefungsarbeit (VA)
                <span class="field-hint">Kein Zwischenschritt gerundet</span>
              </label>
              <input
                class="input-grade"
                id="abuVa"
                type="number"
                min="1"
                max="6"
                step="0.1"
                inputmode="decimal"
                placeholder="5.0"
              />
            </div>
            <div class="field-row">
              <label class="field-label" for="abuSchluss">
                Schlussprüfung
                <span class="field-hint">Nur Endresultat auf 0.1 gerundet</span>
              </label>
              <input
                class="input-grade"
                id="abuSchluss"
                type="number"
                min="1"
                max="6"
                step="0.1"
                inputmode="decimal"
                placeholder="5.0"
              />
            </div>
          </div>
        </article>
      </div>

      <aside class="result" aria-live="polite">
        <div class="result-top">
          <span class="result-label">Abschlussnote</span>
          <span class="risk-chip risk-pending" id="riskBadge">Pending</span>
        </div>

        <div class="grade-big" id="totalGrade">-</div>
        <div class="pass-banner pass-no" id="passBanner">Eingaben fehlen</div>

        <div class="mini-grid">
          <div class="mini-card">
            <div class="mini-label">IPA</div>
            <div class="mini-value" id="miniIpa">-</div>
          </div>
          <div class="mini-card">
            <div class="mini-label">IK</div>
            <div class="mini-value" id="miniIk">-</div>
          </div>
          <div class="mini-card" id="miniEgkCard">
            <div class="mini-label">eGK</div>
            <div class="mini-value" id="miniEgk">-</div>
          </div>
          <div class="mini-card" id="miniAbuCard">
            <div class="mini-label">ABU</div>
            <div class="mini-value" id="miniAbu">-</div>
          </div>
        </div>

        <div class="formula" id="formulaText">
          Formel: IPA×0.4 + IK×0.3 + eGK×0.1 + ABU×0.2
        </div>
        <div class="rounding-note">
          Rundung: IPA-, IK- und eGK-Erfahrungsnoten auf 0.5. IPA-, IK- und
          ABU-Gesamtnote auf 0.1. Abschlussnote auf 0.1.
        </div>
      </aside>
    </section>
  </main>
</BaseLayout>