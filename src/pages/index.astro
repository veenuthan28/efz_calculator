---
import BaseLayout from '../layouts/BaseLayout.astro';

const bfsIds = Array.from({ length: 24 }, (_, index) => `bfsMod${index + 1}`);
const uekIds = Array.from({ length: 7 }, (_, index) => `uekMod${index + 1}`);
const egkSemesterPlan = [
  { semester: 1, hasMath: false },
  { semester: 2, hasMath: true },
  { semester: 3, hasMath: true },
  { semester: 4, hasMath: true },
  { semester: 5, hasMath: false },
  { semester: 6, hasMath: false },
  { semester: 7, hasMath: false },
];
const abuSocIds = Array.from({ length: 7 }, (_, index) => `abuSoc${index + 1}`);
const abuLangIds = Array.from(
  { length: 7 },
  (_, index) => `abuLang${index + 1}`
);
---

<BaseLayout>
  <main class="mx-auto max-w-app stack-xl">
    <section class="glass-card header">
      <span class="badge">BiVo 2021 · Informatiker EFZ</span>
      <h1>QV Notenrechner <span class="accent">IPA + IK</span></h1>
      <p class="subtitle">Schnelle, klare Schätzung deiner Abschlussnote.</p>
      <p class="trust-note">This is an estimation based on your input.</p>
    </section>

    <section class="glass-card toolbar" aria-label="Steuerung">
      <div class="bm-wrap">
        <span id="labelNoBm" class="bm-label active">Ohne BM</span>
        <label class="switch" for="bmToggle">
          <input type="checkbox" id="bmToggle" />
          <span class="track"></span>
          <span class="thumb"></span>
        </label>
        <span id="labelBm" class="bm-label">Mit BM</span>
      </div>
      <button id="resetBtn" class="btn-reset" type="button">
        Eingaben zurücksetzen
      </button>
    </section>

    <section class="layout" aria-label="Notenformular und Resultat">
      <div class="sections stack-lg">
        <article class="section" id="sectionIpa">
          <div class="section-head">
            <h2 class="section-title">IPA · Individuelle Praktische Arbeit</h2>
            <div class="section-meta">
              <span class="pill" id="ipaWeight">40%</span>
              <span class="section-grade" id="ipaGrade">-</span>
            </div>
          </div>
          <div class="section-body">
            <div class="field-row">
              <label class="field-label" for="ipaArbeit">
                Resultat der Arbeit
                <span class="field-hint">Gewichtung 50% · Eingabe 1.0 bis 6.0</span>
              </label>
              <input
                class="input-grade"
                id="ipaArbeit"
                type="number"
                min="1"
                max="6"
                step="0.1"
                inputmode="decimal"
                placeholder="5.0"
              />
            </div>
            <div class="field-row">
              <label class="field-label" for="ipaDok">
                Dokumentation
                <span class="field-hint">Gewichtung 20%</span>
              </label>
              <input
                class="input-grade"
                id="ipaDok"
                type="number"
                min="1"
                max="6"
                step="0.1"
                inputmode="decimal"
                placeholder="5.0"
              />
            </div>
            <div class="field-row">
              <label class="field-label" for="ipaFach">
                Fachgespräch / Präsentation
                <span class="field-hint">Gewichtung 30%</span>
              </label>
              <input
                class="input-grade"
                id="ipaFach"
                type="number"
                min="1"
                max="6"
                step="0.1"
                inputmode="decimal"
                placeholder="5.0"
              />
            </div>
          </div>
        </article>

        <article class="section" id="sectionIk">
          <div class="section-head">
            <h2 class="section-title">IK · Informatikkompetenzen</h2>
            <div class="section-meta">
              <span class="pill" id="ikWeight">30%</span>
              <span class="section-grade" id="ikGrade">-</span>
            </div>
          </div>
          <div class="section-body">
            <div class="subgrade-group" data-mode-group="bfs">
              <div class="subgrade-head">
                <h3>Berufsfachschule · Module</h3>
                <span class="group-grade" id="ikBfsAvg">-</span>
              </div>
              <button type="button" class="mode-toggle" data-toggle-group="bfs">
                <span class="mode-toggle-label">Einzelnoten</span>
                <span class="mode-toggle-icon">⇄</span>
              </button>
              <div class="mode-direct hidden" data-mode-panel="bfs-direct">
                <label class="override-label" for="bfsOverride">BFS-Schnitt (auf 0.5 gerundet)</label>
                <input
                  class="input-grade input-override"
                  id="bfsOverride"
                  data-override="bfs"
                  type="number"
                  min="1"
                  max="6"
                  step="0.1"
                  inputmode="decimal"
                  placeholder="z.B. 4.8"
                />
              </div>
              <div class="mode-detail" data-mode-panel="bfs-detail">
                <p class="group-hint">24 Modulnoten · Schnitt wird auf 0.5 gerundet</p>
                <div class="subgrade-grid">
                  {
                    bfsIds.map((id, index) => (
                      <label class="subgrade-item" for={id}>
                        <span>M{index + 1}</span>
                        <input
                          class="input-grade input-subgrade"
                          id={id}
                          data-group="bfs"
                          type="number"
                          min="1"
                          max="6"
                          step="0.1"
                          inputmode="decimal"
                          placeholder="5.0"
                        />
                      </label>
                    ))
                  }
                </div>
              </div>
            </div>

            <div class="subgrade-group" data-mode-group="uek">
              <div class="subgrade-head">
                <h3>ÜK · Module</h3>
                <span class="group-grade" id="ikUekAvg">-</span>
              </div>
              <button type="button" class="mode-toggle" data-toggle-group="uek">
                <span class="mode-toggle-label">Einzelnoten</span>
                <span class="mode-toggle-icon">⇄</span>
              </button>
              <div class="mode-direct hidden" data-mode-panel="uek-direct">
                <label class="override-label" for="uekOverride">ÜK-Schnitt (auf 0.5 gerundet)</label>
                <input
                  class="input-grade input-override"
                  id="uekOverride"
                  data-override="uek"
                  type="number"
                  min="1"
                  max="6"
                  step="0.1"
                  inputmode="decimal"
                  placeholder="z.B. 4.8"
                />
              </div>
              <div class="mode-detail" data-mode-panel="uek-detail">
                <p class="group-hint">7 ÜK-Noten · Schnitt wird auf 0.5 gerundet</p>
                <div class="subgrade-grid">
                  {
                    uekIds.map((id, index) => (
                      <label class="subgrade-item" for={id}>
                        <span>ÜK {index + 1}</span>
                        <input
                          class="input-grade input-subgrade"
                          id={id}
                          data-group="uek"
                          type="number"
                          min="1"
                          max="6"
                          step="0.1"
                          inputmode="decimal"
                          placeholder="5.0"
                        />
                      </label>
                    ))
                  }
                </div>
              </div>
            </div>
          </div>
        </article>

        <article class="section" id="sectionEgk">
          <div class="section-head">
            <h2 class="section-title">eGK · Erweiterte Grundkompetenzen</h2>
            <div class="section-meta">
              <span class="pill">10%</span>
              <span class="section-grade" id="egkGrade">-</span>
            </div>
          </div>
          <div class="section-body">
            <div class="subgrade-group" data-mode-group="egk">
              <div class="subgrade-head">
                <h3>Semester-Überblick</h3>
                <span class="group-grade" id="egkLiveAvg">-</span>
              </div>
              <button type="button" class="mode-toggle" data-toggle-group="egk">
                <span class="mode-toggle-label">Einzelnoten</span>
                <span class="mode-toggle-icon">⇄</span>
              </button>
              <div class="mode-direct hidden" data-mode-panel="egk-direct">
                <label class="override-label" for="egkOverride">eGK-Schnitt (auf 0.5 gerundet)</label>
                <input
                  class="input-grade input-override"
                  id="egkOverride"
                  data-override="egk"
                  type="number"
                  min="1"
                  max="6"
                  step="0.1"
                  inputmode="decimal"
                  placeholder="z.B. 4.5"
                />
              </div>
              <div class="mode-detail" data-mode-panel="egk-detail">
                <p class="group-hint">
                  Pro Fach auf 0.5, Semesterschnitt auf 0.5, Gesamtschnitt = eGK
                </p>
                <div class="egk-semester-list">
                {
                  egkSemesterPlan.map(({ semester, hasMath }) => (
                    <div class="egk-sem-row" data-egk-semester={semester}>
                      <span class="egk-sem-label">Sem {semester}</span>

                      <label class="subgrade-item" for={`egkSem${semester}Eng`}>
                        <span>Eng</span>
                        <input
                          class="input-grade input-subgrade"
                          id={`egkSem${semester}Eng`}
                          data-group="egk-eng"
                          data-semester={semester}
                          type="number"
                          min="1"
                          max="6"
                          step="0.1"
                          inputmode="decimal"
                          placeholder="5.0"
                        />
                      </label>

                      {
                        hasMath ? (
                          <label class="subgrade-item" for={`egkSem${semester}Math`}>
                            <span>Mathe</span>
                            <input
                              class="input-grade input-subgrade"
                              id={`egkSem${semester}Math`}
                              data-group="egk-math"
                              data-semester={semester}
                              type="number"
                              min="1"
                              max="6"
                              step="0.1"
                              inputmode="decimal"
                              placeholder="5.0"
                            />
                          </label>
                        ) : (
                          <span class="egk-no-math">nur Englisch</span>
                        )
                      }

                      <span class="summary-value egk-sem-avg" data-egk-sem-avg={semester}>-</span>
                    </div>
                  ))
                }
              </div>
              </div>
            </div>
          </div>
        </article>

        <article class="section" id="sectionAbu">
          <div class="section-head">
            <h2 class="section-title">ABU · Allgemeinbildung</h2>
            <div class="section-meta">
              <span class="pill">20%</span>
              <span class="section-grade" id="abuGrade">-</span>
            </div>
          </div>
          <div class="section-body">
            <div class="subgrade-group" data-mode-group="abuSoc">
              <div class="subgrade-head">
                <h3>Erfahrungsnote Gesellschaft</h3>
                <span class="group-grade" id="abuSocAvg">-</span>
              </div>
              <button type="button" class="mode-toggle" data-toggle-group="abuSoc">
                <span class="mode-toggle-label">Einzelnoten</span>
                <span class="mode-toggle-icon">⇄</span>
              </button>
              <div class="mode-direct hidden" data-mode-panel="abuSoc-direct">
                <label class="override-label" for="abuSocOverride">Gesellschaft-Schnitt (auf 0.5 gerundet)</label>
                <input
                  class="input-grade input-override"
                  id="abuSocOverride"
                  data-override="abuSoc"
                  type="number"
                  min="1"
                  max="6"
                  step="0.1"
                  inputmode="decimal"
                  placeholder="z.B. 4.5"
                />
              </div>
              <div class="mode-detail" data-mode-panel="abuSoc-detail">
                <p class="group-hint">7 Semesternoten</p>
                <div class="subgrade-grid compact">
                  {
                    abuSocIds.map((id, index) => (
                      <label class="subgrade-item" for={id}>
                        <span>Sem {index + 1}</span>
                        <input
                          class="input-grade input-subgrade"
                          id={id}
                          data-group="abuSoc"
                          type="number"
                          min="1"
                          max="6"
                          step="0.1"
                          inputmode="decimal"
                          placeholder="5.0"
                        />
                      </label>
                    ))
                  }
                </div>
              </div>
            </div>

            <div class="subgrade-group" data-mode-group="abuLang">
              <div class="subgrade-head">
                <h3>Erfahrungsnote Sprache und Kommunikation</h3>
                <span class="group-grade" id="abuLangAvg">-</span>
              </div>
              <button type="button" class="mode-toggle" data-toggle-group="abuLang">
                <span class="mode-toggle-label">Einzelnoten</span>
                <span class="mode-toggle-icon">⇄</span>
              </button>
              <div class="mode-direct hidden" data-mode-panel="abuLang-direct">
                <label class="override-label" for="abuLangOverride">Sprache/Komm.-Schnitt (auf 0.5 gerundet)</label>
                <input
                  class="input-grade input-override"
                  id="abuLangOverride"
                  data-override="abuLang"
                  type="number"
                  min="1"
                  max="6"
                  step="0.1"
                  inputmode="decimal"
                  placeholder="z.B. 4.5"
                />
              </div>
              <div class="mode-detail" data-mode-panel="abuLang-detail">
                <p class="group-hint">7 Semesternoten</p>
                <div class="subgrade-grid compact">
                  {
                    abuLangIds.map((id, index) => (
                      <label class="subgrade-item" for={id}>
                        <span>Sem {index + 1}</span>
                        <input
                          class="input-grade input-subgrade"
                          id={id}
                          data-group="abuLang"
                          type="number"
                          min="1"
                          max="6"
                          step="0.1"
                          inputmode="decimal"
                          placeholder="5.0"
                        />
                      </label>
                    ))
                  }
                </div>
              </div>
            </div>

            <div class="field-row summary-row">
              <span class="field-label">
                ABU Erfahrungsnote (aus beiden Bereichen)
                <span class="field-hint">Mittelwert aus Gesellschaft und Sprache/Kommunikation</span>
              </span>
              <span class="summary-value" id="abuErfaAvg">-</span>
            </div>

            <div class="field-row">
              <label class="field-label" for="abuVa">
                Vertiefungsarbeit (VA)
                <span class="field-hint">Wird auf 0.5 gerundet</span>
              </label>
              <input
                class="input-grade"
                id="abuVa"
                type="number"
                min="1"
                max="6"
                step="0.1"
                inputmode="decimal"
                placeholder="5.0"
              />
            </div>
            <div class="field-row">
              <label class="field-label" for="abuSchluss">
                Schlussprüfung
                <span class="field-hint">Wird auf 0.5 gerundet</span>
              </label>
              <input
                class="input-grade"
                id="abuSchluss"
                type="number"
                min="1"
                max="6"
                step="0.1"
                inputmode="decimal"
                placeholder="5.0"
              />
            </div>
          </div>
        </article>
      </div>

      <aside class="result" aria-live="polite">
        <div class="result-top">
          <span class="result-label">Abschlussnote</span>
          <span class="risk-chip risk-pending" id="riskBadge">Pending</span>
        </div>

        <div class="grade-big" id="totalGrade">-</div>
        <div class="pass-banner pass-no" id="passBanner">Eingaben fehlen</div>

        <div class="mini-grid">
          <div class="mini-card">
            <div class="mini-label">IPA</div>
            <div class="mini-value" id="miniIpa">-</div>
          </div>
          <div class="mini-card">
            <div class="mini-label">IK</div>
            <div class="mini-value" id="miniIk">-</div>
          </div>
          <div class="mini-card" id="miniEgkCard">
            <div class="mini-label">eGK</div>
            <div class="mini-value" id="miniEgk">-</div>
          </div>
          <div class="mini-card" id="miniAbuCard">
            <div class="mini-label">ABU</div>
            <div class="mini-value" id="miniAbu">-</div>
          </div>
        </div>

        <div class="formula" id="formulaText">
          Formel: IPA×0.4 + IK×0.3 + eGK×0.1 + ABU×0.2
        </div>
        <div class="rounding-note">
          Rundung: IK-BFS/IK-ÜK auf 0.5. eGK je Fach auf 0.5, je Semester auf
          0.5, danach Gesamtnote. ABU-Erfahrungsnote, VA und Schlussprüfung auf
          0.5, ABU-Endnote auf 0.1. Abschlussnote auf 0.1.
        </div>
      </aside>
    </section>
  </main>
</BaseLayout>